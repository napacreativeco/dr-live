{{ 'component--current-artists.css' | asset_url | stylesheet_tag }}
{{ 'card--artist-card.css' | asset_url | stylesheet_tag }}

{% render 'section-header', data: section.settings, destination: '/pages/artists' %}

<div class="current-artists--wrapper" aria-roledescription="carousel" aria-label="Current Artists">
  <ul class="current-artists--list" aria-live="polite" id="slider-items">
    {% for coll in collections %}
      {% case coll.template_suffix %}
          {% when 'artist' %}
          
              {% if coll.metafields.custom.alumni_status == false or coll.metafields.custom.alumni_status == blank %}
                {% render 'artist-card', data: coll %}
              {% endif %}
            

      {% endcase %}
    {% endfor %}
  </ul>

  <div class="controls">
    <div class="next" aria-label="Next slide" aria-controls="slider-items">
      {% render 'svg--right-arrow' %}
    </div>
    <div class="prev" aria-label="Next slide" aria-controls="slider-items">
      {% render 'svg--left-arrow' %}
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Current Artists",
    "tag": "section",
    "class": "current-artists-section section",
    "settings": [
      {
        "type": "text",
        "id": "section_title",
        "label": "Section Title"
      }, {
        "type": "page",
        "id": "link_destination",
        "label": "Link Destination"
      }
    ],
    "presets": [{
      "name": "Current Artists",
      "settings": {
          "section_title": "Current Artists"
        }
    }]
  }
{% endschema %}


<script>
  const slider = document.querySelector('.current-artists--list');
  let isDown = false;
  let startX;
  let scrollLeft;

  slider.addEventListener('mousedown', (e) => {
    isDown = true;
    slider.classList.add('active');
    startX = e.pageX - slider.offsetLeft;
    scrollLeft = slider.scrollLeft;
  });

  slider.addEventListener('mouseleave', () => {
    isDown = false;
    slider.classList.remove('active');
  });

  slider.addEventListener('mouseup', () => {
    isDown = false;
    slider.classList.remove('active');
  });

  slider.addEventListener('mousemove', (e) => {
    if (! isDown) 
      return;
    


    e.preventDefault();
    const x = e.pageX - slider.offsetLeft;
    const walk = (x - startX) * 3; // scroll-fast
    slider.scrollLeft = scrollLeft - walk;
    
  });
</script>